# Copy to .env and fill in. .env is git-ignored — never commit it.

# OpenRouter API key (https://openrouter.ai/keys). OpenAI-compatible endpoint.
OPENROUTER_API_KEY=sk-or-v1-...

# Model used for Problem Abstraction + Framework Retrieval.
# Other options: anthropic/claude-3.5-haiku, anthropic/claude-3.7-sonnet
CONTEXTIFY_MODEL=openai/gpt-4o-mini

# Required by contextify/server.py (hosted API). Callers must send this value
# in an X-API-Key header. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CONTEXTIFY_API_KEY=

